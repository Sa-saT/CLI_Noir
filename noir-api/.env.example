# CLI_Noir backend 環境変数サンプル。
# コピーして .env を作成する: cp .env.example .env
# .env は .gitignore 済み（機密値はコミットしない）。

# --- アプリ ---
DEBUG=false

# --- DB（開発は SQLite。本番は接続URLで上書き） ---
DATABASE_URL=sqlite:///./noir.db

# --- 認証（PyJWT + bcrypt。access 30分 / refresh 7日） ---
# SECRET_KEY は本番で必ずランダムな値に置き換える:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS（フロント noir-client 開発サーバー） ---
CORS_ORIGINS=["http://localhost:3000"]
